# ─────────────────────────────────────────────────────────
# FlowDesk — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────

# ── Clerk Authentication ──────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Clerk redirect routes (these defaults are correct — only change if you rename pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/create-account
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Groq AI ───────────────────────────────────────────────
# Free tier: 1,000 req/day, 500K tokens/day — no credit card required
# Get your key at https://console.groq.com → API Keys
GROQ_API_KEY=gsk_REPLACE_ME

# ── Backend CORS (production only) ───────────────────────
# Comma-separated list of allowed frontend origins.
# In development this defaults to http://localhost:3000 automatically.
# Example: ALLOWED_ORIGINS=https://app.yourcompany.com,https://www.yourcompany.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Backend URL (used by Next.js API calls) ───────────────
# In development this defaults to http://localhost:8000 via lib/api.ts.
# In production set this to your deployed backend URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
